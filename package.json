{
  "name": "ecommerce-3d-mcp",
  "version": "1.0.3",
  "description": "MCP server for e-commerce 3D product visualization — model viewers, AR try-on, product configurators, Shopify integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ecommerce-3d-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "3d",
    "ecommerce",
    "shopify",
    "ar",
    "augmented-reality",
    "product-visualization",
    "model-viewer",
    "configurator",
    "webxr"
  ],
  "author": "Thomas Gorisse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasgorisse/ecommerce-3d-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "tsx": "^4.19.4"
  },
  "mcpName": "io.github.ThomasGorisse/ecommerce-3d-mcp"
}
